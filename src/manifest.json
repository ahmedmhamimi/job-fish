{
  "manifest_version": 3,
  "name": "Job Fish",
  "version": "1.0.0",
  "description": "AI-powered ATS resume optimizer. Surgically tailors your resume to any job description using LLaMA on Groq.",
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "downloads"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "action": {
    "default_title": "Job Fish — ATS Resume Optimizer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}